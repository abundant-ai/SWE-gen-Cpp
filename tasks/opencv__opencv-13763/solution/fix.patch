+{
+    v_uint8 v128 = vx_setall_u8(128);
+    v_int8 su = v_reinterpret_as_s8(v_sub_wrap(u, v128));
+    v_int8 sv = v_reinterpret_as_s8(v_sub_wrap(v, v128));
