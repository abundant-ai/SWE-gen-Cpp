diff --git a/src/re_posix.cc b/src/re_posix.cc
new file mode 100644
index 0000000..e51e2b6
--- /dev/null
+++ b/src/re_posix.cc
@@ -0,0 +1,59 @@
+// Copyright 2014 Google Inc. All rights reserved.
