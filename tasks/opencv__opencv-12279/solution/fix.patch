@@ -717,10 +717,10 @@ template<> struct RGB2Gray<uchar>
 
     RGB2Gray(int _srccn, int blueIdx, const int* coeffs) : srccn(_srccn)
     {
-        const int coeffs0[] = { R2Y, G2Y, B2Y };
+        const int coeffs0[] = { RY15, GY15, BY15 };
