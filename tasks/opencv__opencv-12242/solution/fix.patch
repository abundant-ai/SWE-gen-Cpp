+    CV_CheckType(type, type == CV_32S || type == CV_32F || type == CV_64F, "");
+    if (type == CV_32S || type == CV_32F)  // 32-bit
+        return getSubMatrixImpl<int>(m, idx, layout);
+    if (type == CV_64F)  // 64-bit
+        return getSubMatrixImpl<double>(m, idx, layout);
