-else {
+SPDLOG_INLINE void spdlog::async_logger::flush_(){SPDLOG_TRY{auto pool_ptr = thread_pool_.lock();
+if (!pool_ptr) {
     throw_spdlog_ex("async flush: thread pool doesn't exist anymore");
