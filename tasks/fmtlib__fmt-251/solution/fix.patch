+FMT_FUNC int fmt::fprintf(std::ostream &os, CStringRef format, ArgList args) {
+  MemoryWriter w;
+  printf(w, format, args);
+  os.write(w.data(), w.size());
+  return static_cast<int>(w.size());
+}
