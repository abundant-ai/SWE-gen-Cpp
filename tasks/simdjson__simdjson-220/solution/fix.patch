+bool ParsedJson::iterator::move_to_index(uint32_t index) {
+    assert(is_array());
+    if (down()) {
+      uint32_t i = 0;
+      for (; i < index; i++) {
+        if (!next()) {
+          break;
+        }
+      }
+      if (i == index) {
+        return true;
+      }
+      assert(up());
+    }
+    return false;
+}
 
