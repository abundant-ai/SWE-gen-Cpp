-bool ParsedJson::iterator::relative_move_to(const char * pointer, uint32_t length) {
-    if (length == 0) {
-      // returns the whole document
-      return true;
-    }
-
-    if (pointer[0] != '/') {
-      // '/' must be the first character
-      return false;
-    }
-
-    // finding the key in an object or the index in an array
