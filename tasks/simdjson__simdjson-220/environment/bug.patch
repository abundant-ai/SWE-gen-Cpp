-          key_or_index += '/';
-          offset++;
-          continue;
-        }
-        // "~0" represents "~"
-        if (pointer[offset+1] == '0') {
-          key_or_index += '~';
-          offset++;
-          continue;
-        }
-      }
-      if (pointer[offset] == '\\') {
-        if (pointer[offset+1] == '\\' || pointer[offset+1] == '"' || (pointer[offset+1] <= 0x1F)) {
-          key_or_index += pointer[offset+1];
-          offset++;
-          continue;
-        }
-        return false; // invalid escaped character
-      }
-      if (pointer[offset] == '\"') {
