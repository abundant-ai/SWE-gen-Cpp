-        switch(att_mask.depth())
-        {
-            case CV_32F:
-                run_fused_softmax<float, MaskPolicyFloat<float>>(att_weights, att_mask, softcap, do_softcap, threshold, min_val, is_causal);
-                break;
-            case CV_Bool:
-            case CV_8U:
