diff --git a/templates/cc/register.go b/templates/cc/register.go
index 72fb435..b5e0ce1 100644
--- a/templates/cc/register.go
+++ b/templates/cc/register.go
@@ -19,6 +19,7 @@ func Register(tpl *template.Template) {
 		"cmt":           pgs.C80,
 		"class":         className,
 		"accessor":      accessor,
+		"hasAccessor":   hasAccessor,
 		"ctype":         cType,
 		"err":           err,
 		"errCause":      errCause,
@@ -93,6 +94,16 @@ func accessor(ctx shared.RuleContext) string {
 		ctx.Field.Name())
 }
 
+func hasAccessor(ctx shared.RuleContext) string {
+	if ctx.AccessorOverride != "" {
+		return ctx.AccessorOverride
+	}
+
+	return fmt.Sprintf(
+		"m.has_%s()",
+		ctx.Field.Name())
+}
+
 func className(msg pgs.Message) pgs.TypeName {
 	return msg.TypeName()
 }
