diff --git a/templates/cc/any.go b/templates/cc/any.go
index 5c3612d..a764581 100644
--- a/templates/cc/any.go
+++ b/templates/cc/any.go
@@ -4,12 +4,14 @@ const anyTpl = `{{ $f := .Field }}{{ $r := .Rules }}
 	{{ template "required" . }}
 
 	{{ if $r.In }}
-		if _, ok := {{ lookup $f "InLookup" }}[{{ accessor . }}.GetTypeUrl()]; !ok {
-			return {{ err . "type URL must be in list " $r.In }}
+		{{ $table := lookup $f "InLookup" }}
+		if ({{ hasAccessor . }} && {{ $table }}.find({{ accessor . }}.type_url()) == {{ $table }}.end()) {
+			{{ err . "type URL must be in list " $r.In }}
 		}
 	{{ else if $r.NotIn }}
-		if _, ok := {{ lookup $f "NotInLookup" }}[{{ accessor . }}.GetTypeUrl()]; ok {
-			return {{ err . "type URL must not be in list " $r.NotIn }}
+		{{ $table := lookup $f "NotInLookup" }}
+		if ({{ hasAccessor . }} && {{ $table }}.find({{ accessor . }}.type_url()) != {{ $table }}.end()) {
+			{{ err . "type URL must not be in list " $r.NotIn }}
 		}
 	{{ end }}
 `
