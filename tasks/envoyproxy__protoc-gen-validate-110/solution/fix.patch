+func (fns CCFuncs) packageName(msg pgs.Entity) string {
 	return strings.Join(msg.Package().ProtoName().Split(), "::")
 }
 
@@ -402,3 +402,11 @@ func (fns CCFuncs) staticVarName(msg pgs.Message) string {
