diff --git a/modules/dnn/src/onnx/onnx_importer2.cpp b/modules/dnn/src/onnx/onnx_importer2.cpp
index 4699857552..d740e3f818 100644
--- a/modules/dnn/src/onnx/onnx_importer2.cpp
+++ b/modules/dnn/src/onnx/onnx_importer2.cpp
@@ -2052,6 +2052,16 @@ void ONNXImporter2::parseRMSNormalization(LayerParams& layerParams, const opencv
 
 void ONNXImporter2::parseRandomNormalLike(LayerParams& layerParams, const opencv_onnx::NodeProto& node_proto)
 {
+    if (layerParams.has("dtype"))
+    {
+        int dt = layerParams.get<int>("dtype", -1);
+        if (dt >= 0)
+        {
+            layerParams.set<int>("output_dtype", dataType2cv((opencv_onnx::TensorProto_DataType)dt));
+        }
+        layerParams.erase("dtype");
+    }
+
     layerParams.type = "RandomNormalLike";
     addLayer(layerParams, node_proto);
 }
