-
-  Mat buffer(mat.size(), m_type);
-  for (int y = m_height - 1; y >= 0; --y) {
-    m_strm.getBytes(buffer.ptr(y), static_cast<int>(m_width * buffer.elemSize()));
-    if (is_byte_order_swapped(m_scale_factor)) {
-      for (int i = 0; i < m_width * buffer.channels(); ++i) {
