-  if (buffer.channels() == 3) {
-    cv::cvtColor(buffer, buffer, cv::COLOR_BGR2RGB);
-  }
-
-  CV_Assert(fabs(m_scale_factor) > 0.0f);
-  buffer *= 1.f / fabs(m_scale_factor);
-
-  buffer.convertTo(mat, mat.type());
-
-  return true;
-}
