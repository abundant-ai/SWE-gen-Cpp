diff --git a/.travis.yml b/.travis.yml
index f0fbd22d..cbff7e59 100644
--- a/.travis.yml
+++ b/.travis.yml
@@ -20,5 +20,13 @@ matrix:
     - os: osx
       env: BUILD=Doc
 
+addons:
