+double QRDecode::getTriangleArea(Point2f a, Point2f b, Point2f c)
+{
+    double length_sides[3], perimeter = 0.0, triangle_area = 1.0;
+    length_sides[0] = norm(a - b);
+    length_sides[1] = norm(b - c);
+    length_sides[2] = norm(c - a);
