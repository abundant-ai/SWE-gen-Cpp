+std::string DescriptorInfoName(const FileDescriptor& file) {
+  std::string name =
+      absl::StrReplaceAll(StripProto(file.name()), {{"/", "_"}, {"-", "_"}});
+  absl::AsciiStrToUpper(&name);
+  return absl::StrCat(name, "_DESCRIPTOR_INFO");
+}
